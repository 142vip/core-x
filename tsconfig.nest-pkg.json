{
  "compilerOptions": {
    "target": "ES2023",
    "noLib": false,
    "useDefineForClassFields": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "module": "commonjs",
    "strict": true,
    "useUnknownInCatchVariables": false,
    "declaration": true,
    "outDir": "./dist",
    "removeComments": false,
    "sourceMap": false,
    "skipLibCheck": true
  }
}
